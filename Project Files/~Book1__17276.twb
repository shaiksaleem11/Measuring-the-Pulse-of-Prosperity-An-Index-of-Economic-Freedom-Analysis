                <story-points>
                  <story-point caption='The map shows the top 40 countries with high economic freedom, reflecting stable and growth-oriented economies.' captured-sheet='Top 40 Ranking Countries' id='1' />
                  <story-point caption='The map highlights countries with lower economic freedom, showing areas facing economic and policy challenges.' captured-sheet='Bottom Ranking Countries' id='2' />
                  <story-point caption='The chart shows unemployment levels across countries and their relationship with economic freedom.' captured-sheet='index score board on  unemployment rate' id='3' />
                  <story-point caption='Shows how population size relates to economic freedom across countries.' captured-sheet='Index score based on population' id='4' />
                  <story-point caption='Highlights differences in financial systems and their impact on economic performance.' captured-sheet='Index score Based on financial freedom' id='5' />
                  <story-point caption='Displays global distribution of economic freedom scores in 2022.' captured-sheet='2022 Economic Freedom score' id='6' />
                  <story-point caption='Shows how economic freedom relates to 5-year GDP growth across countries.' captured-sheet='Index score based on 5 year on GDP growth rate' id='7' />
                  <story-point caption='Displays inflation differences and their impact on economic stability.' captured-sheet='Inflation rate in different countries' id='8' />
                  <story-point caption='Shows how inflation and unemployment relate across countries.' captured-sheet='Correlation between inflation and unemployment' id='9' />
                  <story-point caption='Highlights the link between economic output and monetary policy freedom.' captured-sheet='Correlation between GDP(PPP) and monetary freedom' id='10' />
                  <story-point caption='Shows countries with strong economic growth performance.' captured-sheet='Top 40 countries by GDP growth rate' id='11' />
                  <story-point caption='Bottom 40 countries by GDP growth rate&#10;Highlights countries with slower or weaker growth.' captured-sheet='Bottom 40 countries by GDP growth rate' id='12' />
